{
  "manifest_version": 3,
  "name": "Ledry Bridge",
  "version": "0.1.0",
  "description": "Connect approved browser tabs to the local Ledry.",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Ledry"
  },
  "options_page": "options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+Shift+L" },
      "description": "Approve the current tab for Ledry"
    }
  }
}
